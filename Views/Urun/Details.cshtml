@model Urun

@{
    ViewData["Title"] = "Ürün Detayı";
}

<section class="mt-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="card shadow-sm">
                    <img src="~/img/1.jpeg" class="card-img-top" alt="@Model.UrunAdi">
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card p-4 shadow-sm">
                    <h2 class="card-title">@Model.UrunAdi</h2>
                    <p class="text-muted">Ürün ID: @Model.Id</p>
                    <div class="mb-3">
                        <span class="fs-3 fw-bold">@Model.Fiyat ₺</span>
                    </div>
                    <div class="mb-4">
                        <span class="badge bg-@(Model.Aktif ? "success" : "secondary")">
                            @(Model.Aktif ? "Aktif" : "Pasif")
                        </span>
                    </div>

                    <p>Bu ürün hakkında daha fazla bilgi için lütfen müşteri hizmetleri ile iletişime geçin.</p>

                    <div class="d-flex gap-2">
                        <a asp-controller="Urun" asp-action="List" class="btn btn-primary">Listeye Dön</a>
                        <a href="#" class="btn btn-outline-secondary">Sepete Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>