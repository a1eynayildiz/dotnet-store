@model UrunCreateModel
@{
    Layout = "_AdminLayout";
    var kategoriler = ViewBag.Kategoriler as List<Kategori> ?? new List<Kategori>();
}

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">Ürün Ekle</h5>
                <a asp-controller="Urun" asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row mb-3">
                        <label asp-for="UrunAdi" class="col-sm-2 col-form-label">Ürün Adı</label>
                        <div class="col-sm-10">
                            <input asp-for="UrunAdi" class="form-control" />
                            <span asp-validation-for="UrunAdi" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Fiyat" class="col-sm-2 col-form-label">Fiyat</label>
                        <div class="col-sm-10">
                            <input asp-for="Fiyat" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="Fiyat" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="KategoriId" class="col-sm-2 col-form-label">Kategori</label>
                        <div class="col-sm-10">
                            <select asp-for="KategoriId" class="form-select">
                                <option value="0">-- Kategori seçiniz --</option>
                                @foreach (var k in kategoriler)
                                {
                                    <option value="@k.Id">@k.KategoriAdi</option>
                                }
                            </select>
                            <span asp-validation-for="KategoriId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Aciklama" class="col-sm-2 col-form-label">Açıklama</label>
                        <div class="col-sm-10">
                            <textarea asp-for="Aciklama" rows="4" class="form-control"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Resim" class="col-sm-2 col-form-label">Resim</label>
                        <div class="col-sm-10">
                            <input asp-for="Resim" type="file" class="form-control" accept="image/*" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <div class="form-check">
                                <input asp-for="Aktif" class="form-check-input" />
                                <label asp-for="Aktif" class="form-check-label">Aktif</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="Anasayfa" class="form-check-input" />
                                <label asp-for="Anasayfa" class="form-check-label">Anasayfa</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>